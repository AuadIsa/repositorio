// FUN’┐Į’┐ĮO PARA EDITAR UMA DESPESA EXISTENTE
void EditarDespesa() {
    system("cls");
    cout << "=== EDITAR DESPESA ===\n";

    // Primeiro, lista todas as despesas para o usu’┐Įrio escolher
    Relatorio_Despesas();

    FILE *tempFile;
    int encontrou = 0;
    char descricaoBusca[50];

    cout << "\nDigite a descri’┐Į’┐Įo da despesa que deseja editar: ";
    cin.ignore();
    cin.getline(descricaoBusca, sizeof(descricaoBusca));

    DespesasMensais = fopen("despesas.dat", "rb");
    tempFile = fopen("temp.dat", "wb");

    if (!DespesasMensais || !tempFile) {
        cout << "Erro ao abrir arquivos.\n";
        return;
    }

    while (fread(&despesa, sizeof(despesa), 1, DespesasMensais)) {
        if (strcmp(despesa.Descricao, descricaoBusca) == 0) {
            encontrou = 1;
            cout << "Despesa encontrada! Editando...\n\n";

            // Solicita novos dados
            cout << "Nova descri’┐Į’┐Įo [" << despesa.Descricao << "]: ";
            cin.getline(despesa.Descricao, sizeof(despesa.Descricao));

            cout << "Novo valor [" << despesa.valor << "]: ";
            cin >> despesa.valor;

            cout << "Novo m’┐Įs [" << despesa.mes << "]: ";
            cin >> despesa.mes;

            cout << "Nova categoria (1-Mercado, 2-Sa’┐Įde, 3-Lazer, 4-Extras) [" << despesa.categoriaDesp << "]: ";
            cin >> despesa.categoriaDesp;

            despesa.Data = Data(); // Atualiza data/hora da edi’┐Į’┐Įo

            cout << "Despesa editada com sucesso!\n";
        }
        fwrite(&despesa, sizeof(despesa), 1, tempFile);
    }

    fclose(DespesasMensais);
    fclose(tempFile);

    if (encontrou) {
        remove("despesas.dat");
        rename("temp.dat", "despesas.dat");
    } else {
        cout << "Despesa n’┐Įo encontrada!\n";
        remove("temp.dat");
    }

    system("pause");
}

