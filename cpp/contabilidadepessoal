    cout << left << setw(25) << "Origem" << setw(10) << "M’┐Įs"
         << setw(10) << "Ano" << setw(10) << "Valor (R$)" << endl;
    cout << "---------------------------------------------------------------\n";

    while (fread(&ganho, sizeof(ganho), 1, GanhosMensais)) {
        // Verifica se o ganho est’┐Į dentro do per’┐Įodo especificado
        if ((ganho.Data.ano > anoInicio || (ganho.Data.ano == anoInicio && ganho.Data.mes >= mesInicio)) &&
            (ganho.Data.ano < anoFim || (ganho.Data.ano == anoFim && ganho.Data.mes <= mesFim))) {

            cout << left << setw(25) << ganho.Descricao
                 << setw(10) << ganho.Data.mes
                 << setw(10) << ganho.Data.ano
                 << "R$ " << fixed << setprecision(2) << ganho.valor << endl;

            total += ganho.valor;
            encontrou = 1;
        }
    }

    if (!encontrou) {
        cout << "Nenhum ganho encontrado no per’┐Įodo especificado.\n";
    } else {
        cout << "---------------------------------------------------------------\n";
        cout << "TOTAL NO PER’┐ĮODO: R$ " << fixed << setprecision(2) << total << endl;
    }

    fclose(GanhosMensais);
    system("pause");
}

