// ======================================================
TIPO_DATA Data() {
    TIPO_DATA D;
    time_t mytime = time(NULL);
    struct tm tm = *localtime(&mytime);

    D.dia = tm.tm_mday;
    D.mes = tm.tm_mon + 1;
    D.ano = tm.tm_year + 1900;
    D.hora = tm.tm_hour;
    D.min = tm.tm_min;
    D.seg = tm.tm_sec;

    return D;
}

// ======================================================
void Imprime_Data(TIPO_DATA D) {
    cout << setfill('0')
         << setw(2) << D.dia << "/"
         << setw(2) << D.mes << "/"
         << setw(4) << D.ano << " "
         << setw(2) << D.hora << ":"
         << setw(2) << D.min << ":"
         << setw(2) << D.seg
         << setfill(' ');
}

