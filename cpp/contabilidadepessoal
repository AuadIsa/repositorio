// FUN’┐Į’┐ĮO PARA RELAT’┐ĮRIO DE DESPESAS POR PER’┐ĮODO
void RelatorioDespesasPeriodo() {
    system("cls");
    int mesInicio, mesFim, anoInicio, anoFim;

    cout << "=== RELAT’┐ĮRIO DE DESPESAS POR PER’┐ĮODO ===\n";
    cout << "M’┐Įs inicial (1-12): ";
    cin >> mesInicio;
    cout << "Ano inicial: ";
    cin >> anoInicio;
    cout << "M’┐Įs final (1-12): ";
    cin >> mesFim;
    cout << "Ano final: ";
    cin >> anoFim;

    DespesasMensais = fopen("despesas.dat", "rb");
    if (!DespesasMensais) {
        cout << "Nenhum registro encontrado.\n";
        system("pause");
        return;
    }

    float total = 0;
    int encontrou = 0;

    cout << "\n========== DESPESAS NO PER’┐ĮODO: " << mesInicio << "/" << anoInicio;
    cout << " a " << mesFim << "/" << anoFim << " ==========\n";
    cout << left << setw(15) << "Categoria" << setw(25) << "Local"
         << setw(10) << "M’┐Įs" << setw(10) << "Ano" << setw(10) << "Valor (R$)" << endl;
    cout << "---------------------------------------------------------------\n";

    while (fread(&despesa, sizeof(despesa), 1, DespesasMensais)) {
        // Verifica se a despesa est’┐Į dentro do per’┐Įodo especificado
        if ((despesa.Data.ano > anoInicio || (despesa.Data.ano == anoInicio && despesa.Data.mes >= mesInicio)) &&
            (despesa.Data.ano < anoFim || (despesa.Data.ano == anoFim && despesa.Data.mes <= mesFim))) {

            cout << left << setw(15) << GetNomeCategoria(despesa.categoriaDesp)
                 << setw(25) << despesa.Descricao
                 << setw(10) << despesa.Data.mes
                 << setw(10) << despesa.Data.ano
                 << "R$ " << fixed << setprecision(2) << despesa.valor << endl;

            total += despesa.valor;
            encontrou = 1;
        }
    }

    if (!encontrou) {
        cout << "Nenhuma despesa encontrada no per’┐Įodo especificado.\n";
    } else {
        cout << "---------------------------------------------------------------\n";
        cout << "TOTAL NO PER’┐ĮODO: R$ " << fixed << setprecision(2) << total << endl;
    }

    fclose(DespesasMensais);
    system("pause");
}

