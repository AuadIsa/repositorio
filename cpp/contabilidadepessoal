// FUN’┐Į’┐ĮO PARA CALCULAR SALDO MENSAL
void SaldoMensal() {
    system("cls");
    int mes, ano;

    cout << "=== SALDO MENSAL ===\n";
    cout << "M’┐Įs (1-12): ";
    cin >> mes;
    cout << "Ano: ";
    cin >> ano;

    // Calcula total de despesas no m’┐Įs/ano
    float totalDespesas = 0;
    DespesasMensais = fopen("despesas.dat", "rb");
    if (DespesasMensais) {
        while (fread(&despesa, sizeof(despesa), 1, DespesasMensais)) {
            if (despesa.Data.mes == mes && despesa.Data.ano == ano) {
                totalDespesas += despesa.valor;
            }
        }
        fclose(DespesasMensais);
    }

    // Calcula total de ganhos no m’┐Įs/ano
    float totalGanhos = 0;
    GanhosMensais = fopen("ganhos.dat", "rb");
    if (GanhosMensais) {
        while (fread(&ganho, sizeof(ganho), 1, GanhosMensais)) {
            if (ganho.Data.mes == mes && ganho.Data.ano == ano) {
                totalGanhos += ganho.valor;
            }
        }
        fclose(GanhosMensais);
    }

    float saldo = totalGanhos - totalDespesas;

    cout << "\n======= RESUMO MENSAL " << mes << "/" << ano << " =======\n";
    cout << "Total de Ganhos: R$ " << fixed << setprecision(2) << totalGanhos << endl;
    cout << "Total de Despesas: R$ " << fixed << setprecision(2) << totalDespesas << endl;
    cout << "----------------------------------------\n";
    cout << "SALDO: R$ " << fixed << setprecision(2) << saldo << endl;

    if (saldo > 0) {
        cout << "Situa’┐Į’┐Įo: SUPERAVIT\n";
    } else if (saldo < 0) {
        cout << "Situa’┐Į’┐Įo: D’┐ĮFICIT\n";
    } else {
        cout << "Situa’┐Į’┐Įo: EQUILIBRADO\n";
    }

    system("pause");
}
